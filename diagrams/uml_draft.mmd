classDiagram
    class DaytimePreference {
        <<enumeration>>
        DAYTIME
        AFTERNOON
        NIGHTTIME
    }

    class TaskPriority {
        <<enumeration>>
        HIGH
        MEDIUM
        LOW
    }

    class Owner {
        +str name
        +DaytimePreference preference
        +list~Pet~ pets
    }

    class Pet {
        +Owner owner
        +str name
        +str species
        +str breed
        +int age
    }

    class Task {
        +int duration_minutes
        +TaskPriority priority
        +str title
        +Pet pet
        +bool completed
        +complete_task() void
    }

    class DailySchedule {
        +Owner owner
        +date schedule_date
        +int available_minutes
        +list~Task~ tasks
        +generate_schedule() list~Task~
    }

    Owner "1" --> "1" DaytimePreference : preference
    Owner "1" --> "1..*" Pet : has
    Pet "1" --> "0..*" Task : assigned
    Task "1" --> "1" TaskPriority : priority
    DailySchedule "1" --> "1" Owner : for
    DailySchedule "1" --> "0..*" Task : includes
